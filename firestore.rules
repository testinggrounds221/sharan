rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        // List of allowed administrator emails
        request.auth.token.email in ["sb14backup@gmail.com"]
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRSVP(data) {
      return data.keys().size() == 4 &&
             data.guestName != null && data.guestName is string &&
             data.guestName.size() >= 2 && data.guestName.size() <= 100 &&
             data.attendeesCount != null && (data.attendeesCount is int || data.attendeesCount is float) &&
             data.attendeesCount >= 1 && data.attendeesCount <= 20 &&
             data.attendance != null && data.attendance is string &&
             (data.attendance == "wedding" || data.attendance == "reception" || data.attendance == "both" || data.attendance == "declining" || data.attendance == "") &&
             data.createdAt != null && data.createdAt == request.time;
    }

    // RSVPs Collection
    match /rsvps/{rsvpId} {
      allow create: if isValidId(rsvpId) && isValidRSVP(request.resource.data);
      allow read: if true; // Permitted for all users (including master-key users and admins)
      allow delete: if isValidId(rsvpId); // Accessible to both master-key sessions and verified admins under validated ID constraints
    }
  }
}
