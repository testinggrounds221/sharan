rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // RSVPs Collection
    match /rsvps/{rsvpId} {
      allow create: if isValidRSVP(request.resource.data);
      allow get, list, delete: if isAdmin() || isSignedIn();
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email_verified == true && request.auth.token.email == "sb14backup@gmail.com") ||
        request.auth.token.email == "sb14backup@gmail.com"
      );
    }

    function isValidRSVP(data) {
      return data.keys().hasAll(['guestName', 'attendeesCount', 'attendance', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.guestName is string &&
             data.guestName.size() >= 2 &&
             data.guestName.size() <= 120 &&
             data.attendeesCount is int &&
             data.attendeesCount >= 1 &&
             data.attendeesCount <= 20 &&
             data.attendance is string &&
             (data.attendance == "wedding" || data.attendance == "reception" || data.attendance == "both" || data.attendance == "declining" || data.attendance == "");
    }
  }
}
